{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/app/assets/:path*", "destination": "/public/app/assets/:path*" },
    { "source": "/app", "destination": "/public/app/index.html" },
    { "source": "/app/:path*", "destination": "/public/app/index.html" },
    { "source": "/assets/:path*", "destination": "/public/assets/:path*" },
    { "source": "/:path*", "destination": "/public/index.html" }
  ]
}
