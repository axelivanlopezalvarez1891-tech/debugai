{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "../public/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { 
      "source": "/app/:path*", 
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/app/index.html" 
    },
    { 
      "source": "/:path*", 
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/index.html" 
    }
  ]
}
