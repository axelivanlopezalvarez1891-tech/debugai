{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "../public/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/app/:path*", "destination": "/app/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
