# -----------------------------------------------------------------------------
# DebugAI PRO - Production Environment Template
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# For Vercel, add these as Environment Variables in the project settings.

# --- SERVER CONFIG ---
PORT=3000
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here_random_string
ADMIN_SECRET=your_admin_panel_secret_here

# --- SUPABASE (Database & Auth) ---
# Get these from Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- AI PROVIDERS ---
# Groq (Primary & Fast)
GROQ_API_KEY=gsk_your_key_here
# OpenRouter (For Claude 3.5 Sonnet & GPT-4o)
OPENROUTER_API_KEY=sk-or-your-key-here

# --- STRIPE (Payments) ---
# Get these from Stripe Dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# --- APP URLS ---
# Base URL of your production site (e.g., https://debugai-pro.vercel.app)
APP_URL=http://localhost:3000
